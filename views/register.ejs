<% layout('layout/boilerplate') %>

<script>
  document.body.setAttribute("data-page", "register");
</script>

<div class="auth-wrapper">
  <div class="auth-card">

    <h2 class="auth-title">
      <i class="fa-solid fa-user-plus"></i> Create Account
    </h2>
    <p class="auth-subtitle">Join thousands of coders on Learnova</p>

    <% if (typeof error !== "undefined") { %>
      <div class="alert alert-danger">
        <i class="fa-solid fa-circle-exclamation" style="margin-right:6px;"></i><%= error %>
      </div>
    <% } %>

    <form action="/auth/register" method="POST" class="auth-form">

      <div class="form-group">
        <label>Username</label>
        <input
          type="text"
          name="username"
          class="form-control"
          placeholder="Pick a cool username"
          required
        >
      </div>

      <div class="form-group">
        <label>Email</label>
        <input
          type="email"
          name="email"
          class="form-control"
          placeholder="you@example.com"
          required
        >
      </div>

      <div class="form-group">
        <label>Password</label>
        <input
          type="password"
          name="password"
          class="form-control"
          placeholder="Create a strong password"
          required
        >
      </div>

      <button type="submit" class="btn btn-success btn-block">
        Create Account →
      </button>

    </form>

    <p class="auth-switch">
      Already have an account? <a href="/auth/login">Sign in</a>
    </p>

  </div>
</div>
